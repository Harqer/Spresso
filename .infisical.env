# Spresso Industrial Secret Aggregation
# =====================================

# 1. Sentry (Runtime Errors)
SENTRY_DSN=https://REDACTED_SENTRY_KEY@o***REDACTED_SENTRY_ORG_ID***.ingest.us.sentry.io/***REDACTED_SENTRY_ID***
SENTRY_AUTH_TOKEN=REDACTED_PLACEHOLDER

# 2. PostHog (Product Analytics)
NEXT_PUBLIC_POSTHOG_KEY=phc_REDACTED_PLACEHOLDER
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# 3. Langfuse (LLM Observability)
LANGFUSE_PUBLIC_KEY=***REDACTED_LANGFUSE_KEY***
LANGFUSE_SECRET_KEY=REDACTED_LANGFUSE_KEY
LANGFUSE_HOST=https://cloud.langfuse.com

# 4. Cloudflare (Edge Performance)
CLOUDFLARE_API_TOKEN=REDACTED_PLACEHOLDER
