# ==============================================================================
# STRICT ZERO-TRUST POLICY: Block all dotfiles and directories by default
# ==============================================================================
.*

# === ALLOWED EXCEPTIONS (Project Configuration) ===
!.gitignore
!.easignore
!.npmrc
!.firebaserc
!.pre-commit-config.yaml
!.gitlab-ci.yml
!.dockerignore
!.prettierignore
!.editorconfig

# === ALLOWED DIRECTORIES (Source / CI) ===
!.github/
!.agents/
!.claude/

# Allow dot-directories for project skills/agents in subfolders
!**/.agents/
!**/.claude/

# ==============================================================================
# STANDARD EXCLUSIONS (Redundant Safety)
# ==============================================================================
node_modules/
dist/
build/
.gradle/
.idea/
.venv/
__pycache__/
logs/
*.log
local.properties

# Large Binaries & Build Tools
ktlint*
k6
gradle-*.zip

# Android Build Artifacts (Definitive Root Paths)
wearable-retail-app/build/
wear-retail-watch/build/
*.apk
*.aab

# Environment & Secrets (Redundant Protection)
.env
.env.*
*.env
full_env_prod.txt
*_env_*.txt
*_env.txt

# SDK Specific (Meta Wearables)
MWDAT.plist

# Lockfile hygiene
Retail-Agentic-Commerce/package-lock.json
Retail-Agentic-Commerce/yarn.lock
