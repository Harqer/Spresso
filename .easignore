# EAS Production White-list Strategy
# Only include assets required for the Android production build.

# Ignore everything by default
*

# Explicitly allow Android modules and build logic
!wearable-retail-app/
!wear-retail-watch/
!gradle/
!build.gradle.kts
!settings.gradle.kts
!gradle.properties
!gradlew
!gradlew.bat

# Allow EAS and package configs
!app.json
!eas.json
!package.json
!pnpm-lock.yaml
!.easignore
!.gitignore

# Allow standard metadata
!metadata.json
!README.md
